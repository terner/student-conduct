# Supabase — Client-side (NEXT_PUBLIC_ ถูก inject ใน browser bundle)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key

# Supabase — Server-side (secret, ไม่มี NEXT_PUBLIC_)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJ...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJ...

# Line Notify (optional)
LINE_NOTIFY_TOKEN=

# Email (optional)
RESEND_API_KEY=

# File storage
# supabase | google_drive | vercel_blob
STORAGE_PROVIDER=supabase

# Vercel Blob (required when STORAGE_PROVIDER=vercel_blob)
BLOB_READ_WRITE_TOKEN=
# public | private. Defaults: logo/profile public, evidence private.
BLOB_LOGO_ACCESS=public
BLOB_PROFILE_ACCESS=public
BLOB_EVIDENCE_ACCESS=private
