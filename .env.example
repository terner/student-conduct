# Supabase — Client-side (NEXT_PUBLIC_ ถูก inject ใน browser bundle)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key

# Supabase — Server-side (secret, ไม่มี NEXT_PUBLIC_)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJ...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJ...
# Optional but recommended for server-side Auth login rate limits.
# Create a Supabase secret key that starts with sb_secret_ and enable
# Authentication > Rate Limits > IP Address Forwarding in Supabase.
SUPABASE_SECRET_KEY=sb_secret_your_key

# LINE Official Account (optional — for parent notifications)
# Get these from LINE Developers Console → your Channel → Messaging API
LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=
# LIFF ID from LINE Developers Console → your Channel → LIFF
NEXT_PUBLIC_LIFF_ID=
# LIFF app URL (your deployed domain)
NEXT_PUBLIC_LIFF_URL=

# Email (optional)
RESEND_API_KEY=

# File storage
# supabase | google_drive | vercel_blob
STORAGE_PROVIDER=supabase

# Vercel Blob (required when STORAGE_PROVIDER=vercel_blob)
BLOB_READ_WRITE_TOKEN=
# public | private. Private is safest and works with private Blob stores.
BLOB_LOGO_ACCESS=private
BLOB_PROFILE_ACCESS=private
BLOB_EVIDENCE_ACCESS=private

# Upstash Redis / Vercel KV-compatible REST API (optional in local dev; required for production rate limiting and shared cache)
KV_REST_API_URL=
KV_REST_API_TOKEN=
